{
    "containerDefinitions": [
        {
            "name": "backend",
            "image": "568175862303.dkr.ecr.us-east-2.amazonaws.com/midas-backend:d95b69861f182de672450b46883f4ca6b766ac2e",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "backend-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "command": [
                "uvicorn",
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "environment": [
                {
                    "name": "AWS_REGION",
                    "value": "us-east-2"
                },
                {
                    "name": "SQS_QUEUE_URL",
                    "value": "https://sqs.us-east-2.amazonaws.com/568175862303/midas-celery"
                },
                {
                    "name": "PINECONE_INDEX_NAME",
                    "value": "midas-click"
                },
                {
                    "name": "CLERK_JWKS_URL",
                    "value": "https://ace-molly-26.clerk.accounts.dev/.well-known/jwks.json"
                },
                {
                    "name": "CELERY_BROKER_URL",
                    "value": "sqs://"
                },
                {
                    "name": "EMBEDDINGS_ASYNC_ENABLED",
                    "value": "true"
                },
                {
                    "name": "SQS_POLLING_INTERVAL",
                    "value": "1"
                },
                {
                    "name": "CORS_ORIGINS",
                    "value": "https://midas-click.movup.pro"
                },
                {
                    "name": "S3_BUCKET_NAME",
                    "value": "midas-click-resumes"
                },
                {
                    "name": "CLERK_ISSUER",
                    "value": "https://ace-molly-26.clerk.accounts.dev"
                },
                {
                    "name": "LLM_BASE_URL",
                    "value": "https://api.deepseek.com/v1"
                },
                {
                    "name": "CELERY_TASK_DEFAULT_QUEUE",
                    "value": "midas-celery"
                },
                {
                    "name": "EMBEDDINGS_ENABLED",
                    "value": "true"
                },
                {
                    "name": "SQS_VISIBILITY_TIMEOUT",
                    "value": "3600"
                },
                {
                    "name": "SQS_WAIT_TIME_SECONDS",
                    "value": "20"
                },
                {
                    "name": "MONGO_DB_NAME",
                    "value": "midas"
                },
                {
                    "name": "LLM_MODEL",
                    "value": "deepseek-chat"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "LLM_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:568175862303:secret:midas-click-env-6sTWZE:LLM_API_KEY::"
                },
                {
                    "name": "MONGODB_URI",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:568175862303:secret:midas-click-env-6sTWZE:MONGODB_URI::"
                },
                {
                    "name": "PINECONE_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:568175862303:secret:midas-click-env-6sTWZE:PINECONE_API_KEY::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/midas-backend",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "midas-backend",
    "taskRoleArn": "arn:aws:iam::568175862303:role/midas-click-task-role",
    "executionRoleArn": "arn:aws:iam::568175862303:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "enableFaultInjection": false,
    "tags": []
}
