{
    "containerDefinitions": [
        {
            "name": "worker",
            "image": "568175862303.dkr.ecr.us-east-2.amazonaws.com/midas-backend:caed0aae36df3ee6a69218f92b5f6a362892d5ef",
            "cpu": 0,
            "portMappings": [],
            "essential": true,
            "command": [
                "python",
                "-m",
                "celery",
                "-A",
                "app.worker.celery_app:celery_app",
                "worker",
                "--loglevel=info",
                "--concurrency=1",
                "--without-mingle",
                "--without-gossip",
                "--without-heartbeat"
            ],
            "environment": [
                {
                    "name": "EMBEDDING_DIMENSIONS",
                    "value": "768"
                },
                {
                    "name": "AWS_REGION",
                    "value": "us-east-2"
                },
                {
                    "name": "PINECONE_INDEX_NAME",
                    "value": "midas-click"
                },
                {
                    "name": "SQS_QUEUE_URL",
                    "value": "https://sqs.us-east-2.amazonaws.com/568175862303/midas-celery"
                },
                {
                    "name": "EMBEDDING_BATCH_SIZE",
                    "value": "16"
                },
                {
                    "name": "CELERY_BROKER_URL",
                    "value": "sqs://"
                },
                {
                    "name": "EMBEDDINGS_ASYNC_ENABLED",
                    "value": "true"
                },
                {
                    "name": "SQS_POLLING_INTERVAL",
                    "value": "1"
                },
                {
                    "name": "CELERY_TASK_DEFAULT_QUEUE",
                    "value": "midas-celery"
                },
                {
                    "name": "EMBEDDINGS_ENABLED",
                    "value": "true"
                },
                {
                    "name": "SQS_VISIBILITY_TIMEOUT",
                    "value": "3600"
                },
                {
                    "name": "RESUME_CHUNK_MAX_CHARS",
                    "value": "1800"
                },
                {
                    "name": "SQS_WAIT_TIME_SECONDS",
                    "value": "20"
                },
                {
                    "name": "EMBEDDING_MODEL",
                    "value": "BAAI/bge-base-en-v1.5"
                },
                {
                    "name": "MONGO_DB_NAME",
                    "value": "midas"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MONGODB_URI",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:568175862303:secret:midas-click-env-6sTWZE:MONGODB_URI::"
                },
                {
                    "name": "PINECONE_API_KEY",
                    "valueFrom": "arn:aws:secretsmanager:us-east-2:568175862303:secret:midas-click-env-6sTWZE:PINECONE_API_KEY::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/midas-worker",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "midas-worker",
    "taskRoleArn": "arn:aws:iam::568175862303:role/midas-click-task-role",
    "executionRoleArn": "arn:aws:iam::568175862303:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "enableFaultInjection": false,
    "tags": []
}
