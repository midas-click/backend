# API service environment
CORS_ORIGINS=https://your-frontend-domain.example

# MongoDB
MONGO_DB_NAME=your-db-name
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=midas

# AWS S3 resume storage
# Prefer an ECS task role in production. Only set static keys when a task role is not available.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_BUCKET_NAME=your-bucket-name

# Clerk JWT verification
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# LLM job extraction
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding queue behavior
EMBEDDINGS_ENABLED=true
EMBEDDINGS_ASYNC_ENABLED=true

# Required by the API when EMBEDDINGS_ASYNC_ENABLED=true so it can enqueue worker tasks.
CELERY_BROKER_URL=sqs://
CELERY_TASK_DEFAULT_QUEUE=midas-celery
SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/123456789012/midas-celery
SQS_VISIBILITY_TIMEOUT=3600
SQS_WAIT_TIME_SECONDS=20
SQS_POLLING_INTERVAL=1
