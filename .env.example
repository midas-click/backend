# App
CORS_ORIGINS=http://localhost:5173

# MongoDB
MONGO_DB_NAME=your-db-name
MONGODB_URI=mongodb+srv://db_user:db_pass@cluster.mongodb.net/?appName=midas

# AWS S3 resume storage
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# Clerk JWT verification
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# LLM job extraction
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embeddings / RAG
EMBEDDINGS_ENABLED=false
EMBEDDINGS_ASYNC_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=16
EMBEDDING_THREADS=
EMBEDDING_CACHE_DIR=
RESUME_CHUNK_MAX_CHARS=1800

# Background jobs / SQS / Celery
CELERY_BROKER_URL=sqs://
CELERY_TASK_DEFAULT_QUEUE=midas-celery
SQS_QUEUE_URL=
SQS_VISIBILITY_TIMEOUT=3600
SQS_WAIT_TIME_SECONDS=20
SQS_POLLING_INTERVAL=1

